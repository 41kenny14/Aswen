# ============================================================================
# Base Arb Engine V2 — Plantilla de entorno (NO sensible)
# Copiá este archivo a .env y completá SOLO los campos sensibles.
# ============================================================================

# ── 1) Red Base ──────────────────────────────────────────────────────────────
# RPC HTTP recomendado (público):
RPC_URL_BASE=https://mainnet.base.org

# WebSocket (requerido por el scanner). El endpoint público de Base no expone
# WSS utilizable para este bot; usá un proveedor con WebSocket (Alchemy/Infura/QuickNode/Ankr, etc.)
WS_URL_BASE=wss://TU_ENDPOINT_WSS_DE_BASE

# ── 2) Credenciales / contrato (SENSIBLES O VARIABLES) ──────────────────────
# SENSIBLE: clave privada de la wallet que firma transacciones
PRIVATE_KEY=0xREEMPLAZAR_CON_TU_PRIVATE_KEY

# Variable: dirección del contrato FlashLoanArbitrageV2 desplegado
CONTRACT_ADDRESS=0xREEMPLAZAR_CON_TU_CONTRACT_ADDRESS

# ── 3) Aave Base (NO sensible, prellenado) ───────────────────────────────────
AAVE_ADDRESSES_PROVIDER=0xe20fCBdBfFC4Dd138cE8b2E6FBb6CB49777ad64D

# ── 4) Parámetros operativos del motor ───────────────────────────────────────
# Monto máximo a pedir en flash loan (en wei del token base).
# Ejemplo USDC (6 decimales): 1000 USDC = 1000000000
FLASH_LOAN_AMOUNT=1000000000

# Umbrales
MIN_SPREAD_PERCENT=0.3
MIN_PROFIT=1.0
MAX_GAS_COST=0.005
MAX_GAS_PRICE_GWEI=0.05
MAX_SLIPPAGE=1.0
MIN_LIQUIDITY_THRESHOLD=50000
MAX_TAX_THRESHOLD=0.05

# ── 5) Token base / pricing / logs ───────────────────────────────────────────
# USDC en Base mainnet
BASE_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Precio ETH de referencia para estimaciones internas
ETH_PRICE_USD=3000

# debug | info | warn | error
LOG_LEVEL=info

# opcional (alertas)
WEBHOOK_URL=

# opcional (verify contract en Basescan)
BASESCAN_API_KEY=

# ── 6) Protección MEV (elegir una estrategia) ────────────────────────────────
# Opción A: Private RPC
PRIVATE_RPC_URL=

# Opción B: Relayer privado
RELAYER_URL=
RELAYER_AUTH=

# ── 7) Mercados a monitorear (NO sensible, pero DEPENDE DE TU CONFIG) ───────
# Formato TOKEN_PAIRS:
# SYMBOL:TOKEN0:DEC0:TOKEN1:DEC1[, ...]
# Ejemplo USDC/WETH en Base:
TOKEN_PAIRS=USDC-WETH:0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913:6:0x4200000000000000000000000000000000000006:18

# Formato DEX_CONFIGS:
# NAME:VERSION:FACTORY:ROUTER[, ...]
# VERSION: 2 o 3
# Completá con direcciones oficiales verificadas en BaseScan / docs oficiales.
DEX_CONFIGS=UNISWAP_V3:3:0xFACTORY_V3:0xROUTER_V3,SUSHISWAP_V2:2:0xFACTORY_V2:0xROUTER_V2
